# coturn configuration for Together
# This is an EXAMPLE file - copy to turn.conf and customize for your deployment.
#
# Required ports (open these in your firewall):
#   - 3478/tcp + 3478/udp: STUN/TURN
#   - 5349/tcp + 5349/udp: TURN TLS/DTLS (required for iOS)
#   - 49152-65535/udp: Media relay range
#
# Generate credentials:
#   TURN_SECRET=$(openssl rand -hex 32)
#   echo "TURN_SECRET=$TURN_SECRET" >> .env
#
# For Let's Encrypt certificates:
#   cert=/etc/letsencrypt/live/your-domain.com/fullchain.pem
#   pkey=/etc/letsencrypt/live/your-domain.com/privkey.pem

# Network configuration
realm=your-domain.com
listening-port=3478
tls-listening-port=5349

# Use fingerprint for WebRTC compatibility
fingerprint

# Long-term credential mechanism (HMAC-based)
# The secret should match TURN_SECRET in your .env file
lt-cred-mech
use-auth-secret
static-auth-secret=CHANGE_THIS_TO_MATCH_TURN_SECRET

# Media relay range (must match docker-compose.yml)
min-port=49152
max-port=65535

# Logging (stdout for Docker compatibility)
log-file=stdout

# TLS certificates (uncomment and configure for production)
# cert=/etc/ssl/cert.pem
# pkey=/etc/ssl/key.pem

# Deny relay to private IP ranges (security hardening)
denied-peer-ip=0.0.0.0-0.255.255.255
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=100.64.0.0-100.127.255.255
denied-peer-ip=127.0.0.0-127.255.255.255
denied-peer-ip=169.254.0.0-169.254.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.0.0.0-192.0.0.255
denied-peer-ip=192.0.2.0-192.0.2.255
denied-peer-ip=192.88.99.0-192.88.99.255
denied-peer-ip=192.168.0.0-192.168.255.255
denied-peer-ip=198.18.0.0-198.19.255.255
denied-peer-ip=198.51.100.0-198.51.100.255
denied-peer-ip=203.0.113.0-203.0.113.255
denied-peer-ip=240.0.0.0-255.255.255.255

# Allow connections from any IP (use firewall to restrict)
no-multicast-peers
no-cli

# Performance tuning
stale-nonce=600
channel-lifetime=600