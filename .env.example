# ── Images ────────────────────────────────────────────────────────────────────
# Pin to a specific release tag (e.g. v0.0.2) or leave as "latest" for the most
# recent build from main. Images are pulled from Docker Hub (jtjenkins/*).
# To build from source instead, add the build override:
#   docker compose -f docker-compose.yml -f docker-compose.build.yml up -d --build
# TOGETHER_VERSION=latest

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=together
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=together_prod

# ── Server ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_plus_char_secret

# Comma-separated origins allowed for CORS (leave empty to allow all — not
# recommended for production; set to your domain(s) when APP_ENV=production)
ALLOWED_ORIGINS=https://your-domain.com
APP_ENV=production
# Host port the web UI (Nginx) is bound to (default 80)
BIND_PORT=80

# Log level filter (default: info for app, warn for sqlx)
# RUST_LOG=together_server=debug,tower_http=debug,sqlx=info

# ── TURN Server (WebRTC NAT traversal) ────────────────────────────────────────
# Required for iOS cellular connections and restrictive firewalls.
# Without TURN: voice/video works on Wi-Fi but may fail on cellular.
#
# To set up coturn with Docker, see docker-compose.yml and turn.conf.example.
# TURN_URL=turn:turn.your-domain.com:3478
# TURN_SECRET=generate_with_openssl_rand_hex_32